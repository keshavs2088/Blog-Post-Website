<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
    <link rel="stylesheet" href="/css/create.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <%- include('./partials/navbar.ejs') %>
    <main>
      <form
        action = <%= typeof blog !== 'undefined' ? `/edit/${blog.id}` : `/create` %>
        method="POST"
        class="create-post"
        enctype="multipart/form-data"
      >
        <div class="title-create">
          <h1>Create New Blog Post</h1>
          <p>share your thoughts with the world ✨</p>
        </div>
        <div class="blog-title">
          <label for="title">Title</label>
          <input
            type="text"
            id="title"
            name="title"
            placeholder="Enter an engaging title"
            value = "<%= typeof blog !=="undefined" ? blog.title : "" %>"
          />
        </div>

        <div class="blog-img">
          <label for="img-blog"
            >Featured Image
            <span>(Optional)</span>
            <div class="img-upload">
              <img src="/images/image-icon.png" />
              <div>
                <h4>Click to upload an image</h4>
                <p>or drag and drop</p>
                <p>JPG, PNG or WEBP (max. 5MB)</p>
              </div>
            </div>
          </label>
          <input type="file" id="img-blog" name="featured-image" hidden />
        </div>
        <div class="blog-content">
          <label for="content">Content</label>
          <!-- below 2 lines are used imlementing text editor library and a workaround to access it by express -->
          <input type="hidden" name="content" id="content" value = "<%= typeof blog !=="undefined" ? blog.content : "" %>"
          />
          <div id="editor"></div>
        </div>
        <div class="btn-form">
          <div class="btn-cancel">
            <a href="/" class="btn-reset">Cancel</a>
          </div>
          <button type="submit" class="btn-publish">📮 Publish Post</button>
        </div>
      </form>
      <img
        src="/images/create-post.png"
        alt="create post image"
        class="img-create-post"
      />
    </main>
    <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
    <script src="/js/create.js"></script>
  </body>
</html>
