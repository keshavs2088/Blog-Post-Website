<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
    <link rel="stylesheet" href="/css/showBlog.css" />
  </head>
  <body>
    <%- include('./partials/navbar.ejs') %>
    <div class="container">
      <main>
        <a href="/" class="btn-back">← Back to all blogs</a>
        <h1 class="title-blog"><%= blog.title %></h1>
        <div class="date-blog"><%= blog.datePublished %></div>
        
        <!-- show blog image if it exist -->
        <% if(blog.image) {%>
            <img src="/uploads/<%= blog.image %>" class="img-blog" />
        <% } %>
        
        <div class="blog-content"><%- blog.content %></div>
      </main>       
    </div>
  </body>
</html>
